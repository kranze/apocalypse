# Vorlage — kopiere diese Datei nach `.env` und trage deinen Key ein.
# `.env` ist gitignored und wird NIE committet.
#
# Ohne Key läuft der Adjudikator über den deterministischen Regel-Stub.
# Mit Key nutzt er automatisch Claude (API). Alternativ die lokale CLI (Abo).

ANTHROPIC_API_KEY=sk-ant-...

# Backend wählen (stub | claude | cli | auto). Default: auto.
#   auto  = Claude-API wenn ANTHROPIC_API_KEY gesetzt, sonst Stub
#   cli   = echtes Claude über die lokale `claude`-CLI (KEIN API-Key nötig)
#   stub  = deterministischer Regel-Parser (offline, Tests)
# WASTELAND_LLM_BACKEND=cli
# WASTELAND_CLAUDE_CLI=claude        # Pfad/Name der CLI (Default: claude)
# WASTELAND_CLI_TIMEOUT_S=120
